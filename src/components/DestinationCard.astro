---
import type { Destination } from '../data/destinations';

interface Props {
  destination: Destination;
  class?: string;
}

const { destination: d, class: className = '' } = Astro.props;
---

<a
  href={`/destinations/${d.slug}`}
  class:list={['card-japan group block', className]}
  data-photo-id={`dest-card-${d.slug}`}
>
  <!-- Image -->
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={`${d.image.split('?')[0]}?w=600&h=450&fit=crop&q=80`}
      alt={`${d.name}, ${d.prefecture} — Kyushu, Japan`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
      width="600"
      height="450"
    />
    <!-- Gradient -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117]/65 via-[#0d1117]/10 to-transparent"></div>

    <!-- Overlay content -->
    <div class="absolute bottom-0 left-0 right-0 p-4">
      <div class="text-[10px] font-semibold uppercase tracking-widest text-white/60 mb-1">
        {d.prefecture.replace(' Prefecture', '')}
      </div>
      <h3 class="text-white font-serif font-bold text-2xl leading-tight text-hero-shadow">
        {d.name}
      </h3>
    </div>

    <!-- Featured badge -->
    {d.featured && (
      <div class="absolute top-3 right-3 bg-[#c9a84c] text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full">
        Featured
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="p-5">
    <p class="text-[#bc002d] font-medium text-sm mb-2 leading-snug">{d.tagline}</p>
    <p class="text-stone-500 text-sm leading-relaxed line-clamp-2">{d.description}</p>

    <div class="mt-4 pt-4 border-t border-stone-100 flex items-center justify-between text-xs text-stone-400">
      <!-- Travel time -->
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-stone-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {d.travelTime.split(' ').slice(0, 3).join(' ')}
      </span>

      <!-- CTA -->
      <span class="inline-flex items-center gap-1 text-[#bc002d] font-semibold group-hover:gap-2 transition-all duration-200">
        Explore
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
