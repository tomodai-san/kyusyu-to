---
import type { Itinerary } from '../data/itineraries';

interface Props {
  itinerary: Itinerary;
  class?: string;
}

const { itinerary: it, class: className = '' } = Astro.props;

const difficultyColor: Record<string, string> = {
  Easy: 'bg-green-100 text-green-700',
  Moderate: 'bg-amber-100 text-amber-700',
  Active: 'bg-red-100 text-red-700',
};
---

<a
  href={`/itineraries/${it.slug}`}
  class:list={['group bg-white rounded-2xl overflow-hidden shadow-md card-hover flex flex-col', className]}
>
  <div class="relative overflow-hidden aspect-video">
    <img
      src={it.image}
      alt={it.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      width="600"
      height="338"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
    <div class="absolute top-3 left-3 flex gap-2">
      <span class="bg-[#bc002d] text-white text-xs font-semibold px-2.5 py-1 rounded-full">
        {it.duration}
      </span>
      <span class:list={['text-xs font-semibold px-2.5 py-1 rounded-full', difficultyColor[it.difficulty]]}>
        {it.difficulty}
      </span>
    </div>
    <div class="absolute bottom-4 left-4 right-4">
      <div class="text-white/70 text-xs font-medium uppercase tracking-wider mb-1">{it.theme}</div>
      <h3 class="text-white font-serif font-bold text-xl leading-snug drop-shadow">{it.title}</h3>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-1">
    <p class="text-stone-600 text-sm leading-relaxed line-clamp-3 flex-1">{it.description}</p>

    <!-- Route -->
    <div class="mt-4 flex items-center gap-1.5 flex-wrap">
      {it.route.map((stop, i) => (
        <>
          <span class="text-xs font-medium text-[#1a2744]">{stop}</span>
          {i < it.route.length - 1 && (
            <svg class="w-3 h-3 text-stone-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          )}
        </>
      ))}
    </div>

    <div class="mt-4 pt-4 border-t border-stone-100 flex items-center justify-between">
      <span class="text-sm font-semibold text-stone-700">{it.estimatedCost}</span>
      <span class="text-[#bc002d] text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
        View Plan
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
