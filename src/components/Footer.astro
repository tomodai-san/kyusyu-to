---
const currentYear = new Date().getFullYear();

const footerLinks = {
  Destinations: [
    { href: '/destinations/fukuoka', label: 'Fukuoka' },
    { href: '/destinations/nagasaki', label: 'Nagasaki' },
    { href: '/destinations/beppu', label: 'Beppu' },
    { href: '/destinations/kumamoto', label: 'Kumamoto' },
    { href: '/destinations/kagoshima', label: 'Kagoshima' },
    { href: '/destinations/yufuin', label: 'Yufuin' },
  ],
  'Plan Your Trip': [
    { href: '/itineraries', label: 'All Itineraries' },
    { href: '/ryokan', label: 'Best Ryokan' },
    { href: '/blog', label: 'Travel Blog' },
    { href: '/blog/how-to-experience-ryokan', label: 'Ryokan Guide' },
    { href: '/blog/best-time-to-visit-kyushu', label: 'When to Visit' },
  ],
  Info: [
    { href: '/about', label: 'About Us' },
    { href: '/contact', label: 'Contact' },
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/disclaimer', label: 'Affiliate Disclaimer' },
  ],
};
---

<footer class="bg-[#1a2744] text-white">
  <!-- Top section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#bc002d] rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-xl">九</span>
          </div>
          <span class="font-serif font-bold text-xl">Kyushu Explorer</span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Your independent guide to travelling Japan's incredible southern island. Honest recommendations, no fluff — just everything you need for the perfect Kyushu trip.
        </p>
        <p class="text-white/40 text-xs mt-4">
          We may earn a commission from affiliate links at no extra cost to you.
        </p>
        <!-- Social links -->
        <div class="flex gap-3 mt-6">
          {[
            { label: 'Pinterest', path: 'M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z' },
            { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
          ].map(s => (
            <a
              href="#"
              aria-label={s.label}
              class="w-9 h-9 rounded-full bg-white/10 hover:bg-[#bc002d] flex items-center justify-center transition-colors"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d={s.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([heading, links]) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">{heading}</h3>
          <ul class="space-y-2.5">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-white/70 hover:text-white text-sm transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-xs">
        &copy; {currentYear} Kyushu Explorer. All rights reserved.
      </p>
      <p class="text-white/40 text-xs text-center">
        Affiliate links on this site may earn us a commission — this helps keep the site free and independent.
      </p>
    </div>
  </div>
</footer>
