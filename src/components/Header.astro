---
import { destinations } from '../data/destinations';

const navLinks = [
  { href: '/destinations', label: 'Destinations', hasDropdown: true },
  { href: '/ryokan',       label: 'Best Ryokan',  hasDropdown: false },
  { href: '/itineraries',  label: 'Itineraries',  hasDropdown: false },
  { href: '/blog',         label: 'Travel Blog',  hasDropdown: false },
];

const currentPath = Astro.url.pathname;
---

<!-- Scroll progress bar -->
<div
  id="scroll-progress"
  class="fixed top-0 left-0 right-0 h-0.5 bg-[#bc002d] z-[60] origin-left"
  style="transform: scaleX(0)"
  aria-hidden="true"
></div>

<header
  class="fixed top-0.5 left-0 right-0 z-50 transition-all duration-300"
  id="site-header"
  data-scrolled="false"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[4.5rem]">

      <!-- ── Logo ─────────────────────────────────────── -->
      <a href="/" class="flex items-center gap-3 group flex-shrink-0" aria-label="Kyushu Explorer home">
        <!-- Torii-inspired mark -->
        <div class="relative w-9 h-9 flex-shrink-0">
          <div class="absolute inset-0 bg-[#bc002d] rounded-lg shadow-md group-hover:scale-105 transition-transform duration-200"></div>
          <span class="absolute inset-0 flex items-center justify-center text-white font-bold text-xl leading-none font-serif select-none">
            九
          </span>
        </div>
        <div class="leading-snug">
          <div class="font-serif font-bold text-[1.05rem] transition-colors duration-300" id="logo-name">
            Kyushu Explorer
          </div>
          <div class="text-[0.65rem] tracking-widest uppercase transition-colors duration-300 hidden sm:block" id="logo-tagline">
            Japan's Southern Island
          </div>
        </div>
      </a>

      <!-- ── Desktop Nav ───────────────────────────────── -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
        {navLinks.map(link => (
          link.hasDropdown ? (
            <!-- Destinations with mega-dropdown -->
            <div class="relative group">
              <a
                href={link.href}
                class:list={[
                  'relative flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-lg transition-colors duration-200 nav-link',
                  currentPath.startsWith(link.href) ? 'nav-active' : ''
                ]}
                aria-haspopup="true"
              >
                {link.label}
                <svg class="w-3.5 h-3.5 opacity-60 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </a>

              <!-- Dropdown panel -->
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
                <div class="bg-white rounded-2xl shadow-2xl border border-stone-100 p-4 w-[520px]">
                  <!-- Header row -->
                  <div class="flex items-center justify-between mb-3 pb-3 border-b border-stone-100">
                    <span class="text-xs font-semibold uppercase tracking-widest text-stone-400">Destinations in Kyushu</span>
                    <a href="/destinations" class="text-xs font-semibold text-[#bc002d] hover:underline flex items-center gap-1">
                      View all
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  </div>
                  <!-- City grid -->
                  <div class="grid grid-cols-3 gap-2">
                    {destinations.map(d => (
                      <a
                        href={`/destinations/${d.slug}`}
                        class="group/item flex items-center gap-2.5 p-2.5 rounded-xl hover:bg-[#faf8f3] transition-colors"
                      >
                        <div class="w-9 h-9 rounded-lg overflow-hidden flex-shrink-0 photo-frame">
                          <img
                            src={`${d.image.split('?')[0]}?w=80&q=70`}
                            alt={d.name}
                            class="w-full h-full object-cover"
                            loading="lazy"
                            width="36"
                            height="36"
                          />
                        </div>
                        <div class="min-w-0">
                          <div class="font-semibold text-[#1a2744] text-sm leading-tight group-hover/item:text-[#bc002d] transition-colors truncate">
                            {d.name}
                          </div>
                          <div class="text-[0.65rem] text-stone-400 leading-tight truncate">{d.prefecture.replace(' Prefecture', '')}</div>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'relative px-4 py-2 text-sm font-medium rounded-lg transition-colors duration-200 nav-link',
                currentPath.startsWith(link.href) ? 'nav-active' : ''
              ]}
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- ── Right actions ─────────────────────────────── -->
      <div class="hidden lg:flex items-center gap-3 flex-shrink-0">
        <a
          href="/itineraries"
          class="btn-primary text-sm py-2.5 px-5"
        >
          Plan Your Trip
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- ── Mobile hamburger ──────────────────────────── -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-xl transition-colors duration-200 nav-link"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- ── Mobile menu panel ─────────────────────────────────────── -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden"
  aria-modal="true"
  role="dialog"
>
  <!-- Backdrop -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-[#0d1117]/60 backdrop-blur-sm"></div>

  <!-- Slide-in panel -->
  <div
    id="mobile-panel"
    class="absolute right-0 top-0 bottom-0 w-[320px] max-w-full bg-[#1a2744] shadow-2xl flex flex-col translate-x-full transition-transform duration-300"
  >
    <!-- Panel header -->
    <div class="flex items-center justify-between px-6 h-16 border-b border-white/10">
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-7 h-7 bg-[#bc002d] rounded-md flex items-center justify-center">
          <span class="text-white font-bold font-serif text-base">九</span>
        </div>
        <span class="font-serif font-bold text-white">Kyushu Explorer</span>
      </a>
      <button id="mobile-close-btn" class="p-1.5 text-white/60 hover:text-white rounded-lg hover:bg-white/10 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 overflow-y-auto px-4 py-5 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'bg-[#bc002d]/20 text-white'
              : 'text-white/80 hover:text-white hover:bg-white/10'
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Destinations list on mobile -->
      <div class="pt-2 pb-1">
        <div class="px-4 py-2 text-xs font-semibold uppercase tracking-widest text-white/30">All Destinations</div>
        {destinations.map(d => (
          <a
            href={`/destinations/${d.slug}`}
            class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-white/70 hover:text-white hover:bg-white/10 transition-colors text-sm"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-[#bc002d] flex-shrink-0"></span>
            {d.name}
          </a>
        ))}
      </div>
    </nav>

    <!-- Panel footer CTA -->
    <div class="px-4 py-5 border-t border-white/10">
      <a href="/itineraries" class="btn-primary w-full justify-center">
        Plan Your Trip
      </a>
    </div>
  </div>
</div>

<!-- Spacer for non-hero pages -->
<div class="h-16 lg:h-[4.5rem]" id="header-spacer" style="display:none"></div>

<style>
  /* Dynamic nav link colours — JS sets data-scrolled on header */
  #site-header[data-scrolled="false"] .nav-link      { color: rgba(255,255,255,0.88); }
  #site-header[data-scrolled="false"] .nav-link:hover { color: #fff; background: rgba(255,255,255,0.08); }
  #site-header[data-scrolled="false"] .nav-active     { color: #fff; background: rgba(255,255,255,0.15); }

  #site-header[data-scrolled="true"]  .nav-link      { color: #44403c; }
  #site-header[data-scrolled="true"]  .nav-link:hover { color: #bc002d; background: #faf8f3; }
  #site-header[data-scrolled="true"]  .nav-active     { color: #bc002d; background: rgba(188,0,45,0.08); }

  /* Mobile btn inherits nav-link colour above */
  #mobile-menu-btn { color: inherit; }
</style>

<script>
  const header   = document.getElementById('site-header')!;
  const spacer   = document.getElementById('header-spacer')!;
  const mobileMenu  = document.getElementById('mobile-menu')!;
  const mobilePanel = document.getElementById('mobile-panel')!;
  const openBtn  = document.getElementById('mobile-menu-btn')!;
  const closeBtn = document.getElementById('mobile-close-btn')!;
  const backdrop = document.getElementById('mobile-backdrop')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;
  const progress  = document.getElementById('scroll-progress');

  const isHeroPage = !!document.querySelector('[data-hero-page]');

  /* ── Scroll state ──────────────────────────────────────────── */
  function applyScrollState(scrolled: boolean) {
    header.dataset.scrolled = String(scrolled);
    if (scrolled) {
      header.classList.add('bg-white/95', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-stone-100/80');
      header.classList.remove('bg-transparent');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-stone-100/80');
      header.classList.add('bg-transparent');
    }
  }

  function onScroll() {
    applyScrollState(window.scrollY > 60);

    // scroll progress bar (no-op if CSS supports scroll-timeline)
    if (progress && !CSS.supports('animation-timeline', 'scroll()')) {
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      (progress as HTMLElement).style.transform = `scaleX(${Math.min(pct, 1)})`;
    }
  }

  if (isHeroPage) {
    applyScrollState(false);
    window.addEventListener('scroll', onScroll, { passive: true });
  } else {
    applyScrollState(true);
    spacer.style.display = 'block';
  }

  /* ── Mobile panel ──────────────────────────────────────────── */
  function openMobile() {
    mobileMenu.classList.remove('hidden');
    requestAnimationFrame(() => {
      mobilePanel.classList.remove('translate-x-full');
    });
    document.body.style.overflow = 'hidden';
    openBtn.setAttribute('aria-expanded', 'true');
    iconMenu.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }

  function closeMobile() {
    mobilePanel.classList.add('translate-x-full');
    setTimeout(() => mobileMenu.classList.add('hidden'), 300);
    document.body.style.overflow = '';
    openBtn.setAttribute('aria-expanded', 'false');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  openBtn.addEventListener('click', openMobile);
  closeBtn.addEventListener('click', closeMobile);
  backdrop.addEventListener('click', closeMobile);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMobile(); });
</script>
